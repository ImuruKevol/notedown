div(class="h-screen overflow-hidden bg-white text-stone-950 dark:bg-zinc-950 dark:text-zinc-50")
    div(*ngIf="!isSettingsRoute", class="app-drag flex h-12 items-center justify-between border-b border-stone-200 bg-[#fbfbfa]/95 px-3 backdrop-blur lg:hidden dark:border-zinc-800 dark:bg-zinc-950/95")
        button(type="button", title="Open sidebar", class="flex size-9 items-center justify-center rounded-md text-stone-600 hover:bg-stone-200/70 hover:text-stone-950 dark:text-zinc-300 dark:hover:bg-zinc-800", (click)="toggleSidebar($event)")
            svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-5")
                rect(x="3", y="4", width="18", height="16", rx="2")
                path(d="M9 4v16")
        img(src="assets/brand/logo-black.svg", alt="Notedown", class="h-6 w-auto dark:hidden")
        img(src="assets/brand/logo-white.svg", alt="Notedown", class="hidden h-6 w-auto dark:block")
        span(class="size-9")

    div(*ngIf="mobileOpen && !isSettingsRoute", class="fixed inset-0 z-50 lg:hidden")
        button(type="button", title="Close sidebar", class="absolute inset-0 bg-stone-950/30 backdrop-blur-sm", (click)="closeSidebar()")
        aside([class]="mobileSidebarClass()")
            wiz-component-nav-sidebar(class="block h-full min-h-0")

    aside(*ngIf="!isSettingsRoute", [class]="desktopSidebarClass()")
        wiz-component-nav-sidebar(class="block h-full min-h-0")

    main([class]="mainClass()")
        router-outlet

    div(*ngIf="paletteOpen", class="fixed inset-0 z-[80] bg-stone-950/30 px-3 pt-[14vh] backdrop-blur-sm dark:bg-black/45")
        button(type="button", title="Close command palette", class="absolute inset-0 z-0 size-full cursor-default", (click)="closePalette()")
        section(class="app-no-drag relative z-10 mx-auto flex w-full max-w-2xl flex-col overflow-hidden rounded-lg border border-stone-200 bg-white shadow-2xl shadow-stone-950/20 dark:border-zinc-800 dark:bg-zinc-950 dark:shadow-black/40", (click)="$event.stopPropagation()")
            div(class="flex h-14 shrink-0 items-center gap-3 border-b border-stone-200 px-4 dark:border-zinc-800")
                svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-5 shrink-0 text-stone-400 dark:text-zinc-500", aria-hidden="true")
                    circle(cx="11", cy="11", r="7")
                    path(d="m20 20-3.5-3.5")
                input(type="text", data-command-palette-input="true", [(ngModel)]="paletteQuery", (ngModelChange)="onPaletteQueryChange($event)", (keydown)="handlePaletteKeydown($event)", [placeholder]="palettePlaceholder()", class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-[16px] font-medium text-stone-900 outline-none placeholder:text-stone-400 focus:ring-0 dark:text-zinc-100 dark:placeholder:text-zinc-600")
                span(class="hidden shrink-0 rounded border border-stone-200 px-1.5 py-0.5 text-[11px] font-semibold text-stone-400 sm:inline dark:border-zinc-800 dark:text-zinc-500") esc
            div(class="flex h-9 shrink-0 items-center justify-between border-b border-stone-100 px-4 text-[12px] dark:border-zinc-900")
                span(class="min-w-0 truncate font-semibold text-stone-500 dark:text-zinc-400") {{paletteModeLabel()}}
                span(class="shrink-0 text-stone-400 dark:text-zinc-500") {{paletteHintLabel()}}
            div(data-command-palette-list="true", class="max-h-[min(56vh,420px)] min-h-36 overflow-y-auto p-1.5")
                button(type="button", *ngFor="let item of paletteItems; let index = index", [attr.data-command-palette-index]="index", [class]="paletteItemClass(index)", (mousemove)="selectPaletteItemByPointer(index)", (mousedown)="$event.preventDefault()", (click)="selectPaletteItem(item, $event)")
                    span([class]="paletteIconClass(index)")
                        svg(*ngIf="item.type === 'note-title' || item.type === 'note-body'", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z")
                            path(d="M14 2v5h5")
                            path(d="M8 13h8")
                            path(d="M8 17h5")
                        svg(*ngIf="item.type === 'workspace'", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M3 7.5A2.5 2.5 0 0 1 5.5 5H10l2 2h6.5A2.5 2.5 0 0 1 21 9.5v7A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5z")
                        svg(*ngIf="item.type === 'command'", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.52a2 2 0 0 1-1 1.72l-.15.1a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.38a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.52a2 2 0 0 1 1-1.72l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z")
                            circle(cx="12", cy="12", r="3")
                    span(class="min-w-0 flex-1")
                        span(class="block truncate text-[13px] font-semibold") {{item.title}}
                        span([class]="paletteSubtitleClass(index)") {{item.subtitle}}
                    span(*ngIf="item.type === 'note-body'", [class]="paletteBadgeClass(index)") 내용
                    span(*ngIf="item.type === 'note-title'", [class]="paletteBadgeClass(index)") 제목
                    span(*ngIf="item.type === 'workspace'", [class]="paletteBadgeClass(index)") {{item.workspace?.count || 0}}
                div(*ngIf="paletteItems.length === 0", class="flex h-36 items-center justify-center px-6 text-center text-[13px] text-stone-400 dark:text-zinc-500")
                    span 검색 결과가 없습니다.
