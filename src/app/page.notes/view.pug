section(class="flex h-full min-h-0 flex-col bg-white text-stone-950 dark:bg-zinc-950 dark:text-zinc-50")
    input(type="file", multiple, data-note-attachment-input="true", [attr.accept]="attachmentInputAccept || null", class="hidden", (change)="handleAttachmentInputChange($event)")
    ng-container(*ngIf="hasSelectedNote || showSyncConflictViewer()")
        header(class="app-drag flex h-14 shrink-0 items-center justify-between border-b border-stone-200 bg-white px-5 dark:border-zinc-800 dark:bg-zinc-950")
            div(class="min-w-0 flex flex-1 items-center")
                div(*ngIf="!editingTitle", class="min-w-0 flex max-w-full items-center gap-1.5")
                    span(class="min-w-0 truncate text-[16px] font-semibold text-stone-900 dark:text-zinc-100", [title]="showSyncConflictViewer() ? syncConflictPathLabel() : noteTitleLabel()") {{showSyncConflictViewer() ? '동기화 충돌' : noteTitleLabel()}}
                    button(*ngIf="!showSyncConflictViewer()", type="button", title="Edit title", aria-label="Edit title", class="flex size-8 shrink-0 items-center justify-center rounded-md text-stone-400 transition hover:bg-stone-100 hover:text-stone-950 dark:text-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-50", (click)="startTitleEdit()")
                        svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M12 20h9")
                            path(d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z")
                input(*ngIf="editingTitle && !showSyncConflictViewer()", type="text", [(ngModel)]="titleDraft", (keydown.enter)="commitTitleEdit()", (keydown.escape)="cancelTitleEdit()", (blur)="commitTitleEdit()", data-note-title-input="true", class="app-no-drag min-w-0 w-full border-0 bg-transparent p-0 text-[16px] font-semibold text-stone-900 outline-none placeholder:text-stone-300 focus:ring-0 dark:text-zinc-100 dark:placeholder:text-zinc-700", placeholder="제목 없음")
            div(class="flex shrink-0 items-center gap-1.5 pl-4")
                span(*ngIf="showSyncConflictViewer()", class="inline-flex h-7 items-center rounded-full bg-amber-100 px-2.5 text-[12px] font-semibold text-amber-800 dark:bg-amber-500/20 dark:text-amber-100") 충돌 {{syncConflicts.length}}건
                span(*ngIf="!showSyncConflictViewer()", class="hidden whitespace-nowrap text-[12px] text-stone-400 sm:inline dark:text-zinc-500") 생성: {{createdAtLabel()}} · 저장: {{lastSavedLabel()}}
                div(*ngIf="!showSyncConflictViewer() && showHeaderModeButtons()", class="flex gap-0.5 rounded-lg border border-stone-200 bg-white/95 p-0.5 shadow-sm backdrop-blur dark:border-zinc-800 dark:bg-zinc-900/95")
                    button(type="button", title="Write", data-view-mode="write", [class]="modeButtonClass('write')", (click)="setMode('write')")
                        svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M12 20h9")
                            path(d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z")
                    button(*ngIf="shouldShowSplitMode()", type="button", title="Split", data-view-mode="split", [class]="modeButtonClass('split')", (click)="setMode('split')")
                        svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            rect(x="3", y="4", width="18", height="16", rx="2")
                            path(d="M12 4v16")
                    button(type="button", title="Preview", data-view-mode="preview", [class]="modeButtonClass('preview')", (click)="setMode('preview')")
                        svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z")
                            circle(cx="12", cy="12", r="3")
                div(*ngIf="!showSyncConflictViewer()", class="flex shrink-0 items-center gap-0.5")
                    button(type="button", title="Attachments", [class]="attachmentButtonClass()", (click)="toggleAttachmentPanel()", [attr.aria-pressed]="attachmentPanelOpen")
                        svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48")
                        span(class="tabular-nums") {{attachmentCount()}}
                    button(type="button", title="Save PDF", class="flex size-8 items-center justify-center rounded-md text-stone-500 transition hover:bg-stone-100 hover:text-stone-950 disabled:cursor-wait disabled:opacity-60 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-50", (click)="openPdfExportOptionsOrExport()", [disabled]="pdfExportBusy")
                        svg(*ngIf="!pdfExportBusy", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                            path(d="M14 2v6h6")
                            path(d="M12 12v6")
                            path(d="m9 15 3 3 3-3")
                        svg(*ngIf="pdfExportBusy", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", class="size-4 animate-spin")
                            circle(cx="12", cy="12", r="9", stroke="currentColor", stroke-width="2", opacity=".25")
                            path(d="M21 12a9 9 0 0 0-9-9", stroke="currentColor", stroke-width="2", stroke-linecap="round")

        div(class="relative min-h-0 flex-1 bg-white dark:bg-zinc-950", data-note-editor-shell="true")
            div(*ngIf="pdfExportBusy", class="pointer-events-none absolute inset-x-4 bottom-20 z-50 flex justify-center")
                div(class="flex max-w-[calc(100vw-2rem)] items-center gap-3 rounded-md border border-stone-200 bg-white/95 px-4 py-3 text-left shadow-xl backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/95", role="status", aria-live="polite")
                    svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", class="size-5 shrink-0 animate-spin text-stone-700 dark:text-zinc-200")
                        circle(cx="12", cy="12", r="9", stroke="currentColor", stroke-width="2", opacity=".25")
                        path(d="M21 12a9 9 0 0 0-9-9", stroke="currentColor", stroke-width="2", stroke-linecap="round")
                    div(class="min-w-0")
                        p(class="text-[13px] font-semibold text-stone-900 dark:text-zinc-100") PDF 저장 중
                        p(class="mt-0.5 text-[12px] text-stone-500 dark:text-zinc-400") {{pdfExportMessage}}
            div(*ngIf="pdfExportOptionsOpen && !showSyncConflictViewer()", class="absolute inset-0 z-50 flex items-center justify-center bg-black/20 px-4 backdrop-blur-sm", (click)="closePdfExportOptions()")
                div(class="w-full max-w-[420px] rounded-md border border-stone-200 bg-white p-4 shadow-2xl dark:border-zinc-800 dark:bg-zinc-950", role="dialog", aria-modal="true", aria-label="PDF export options", (click)="$event.stopPropagation()")
                    div(class="flex items-start justify-between gap-3")
                        div(class="min-w-0")
                            p(class="text-[14px] font-semibold text-stone-900 dark:text-zinc-100") PDF 내보내기
                            p(class="mt-1 text-[12px] text-stone-500 dark:text-zinc-400") {{pdfAttachmentOptionDetail()}}
                        button(type="button", title="Close", class="flex size-8 shrink-0 items-center justify-center rounded-md text-stone-500 transition hover:bg-stone-100 hover:text-stone-950 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-50", (click)="closePdfExportOptions()")
                            svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                path(d="M18 6 6 18")
                                path(d="m6 6 12 12")
                    div(class="mt-4 grid gap-2")
                        button(type="button", class="flex min-h-[72px] w-full items-center gap-3 rounded-md border border-stone-200 bg-white px-3 py-2.5 text-left transition hover:bg-stone-50 disabled:cursor-wait disabled:opacity-60 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:bg-zinc-800", (click)="exportNotePdf('markdown-images')", [disabled]="pdfExportBusy")
                            span(class="flex size-9 shrink-0 items-center justify-center rounded-md bg-stone-100 text-stone-700 dark:bg-zinc-800 dark:text-zinc-200")
                                svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                    path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                                    path(d="M14 2v6h6")
                                    path(d="M10 13h4")
                                    path(d="M10 17h4")
                            span(class="min-w-0")
                                span(class="block text-[13px] font-semibold text-stone-900 dark:text-zinc-100") Markdown 이미지 PDF
                                span(class="mt-0.5 block text-[12px] leading-5 text-stone-500 dark:text-zinc-400") 본문에 삽입된 이미지만 포함
                        button(type="button", class="flex min-h-[72px] w-full items-center gap-3 rounded-md border border-stone-200 bg-white px-3 py-2.5 text-left transition hover:bg-stone-50 disabled:cursor-wait disabled:opacity-60 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:bg-zinc-800", (click)="exportNotePdf('zip-with-attachments')", [disabled]="pdfExportBusy")
                            span(class="flex size-9 shrink-0 items-center justify-center rounded-md bg-stone-100 text-stone-700 dark:bg-zinc-800 dark:text-zinc-200")
                                svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                    path(d="M21 8v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h7a2 2 0 0 1 2 2Z")
                                    path(d="M12 11v6")
                                    path(d="m9 14 3 3 3-3")
                            span(class="min-w-0")
                                span(class="block text-[13px] font-semibold text-stone-900 dark:text-zinc-100") PDF + 모든 첨부 ZIP
                                span(class="mt-0.5 block text-[12px] leading-5 text-stone-500 dark:text-zinc-400") PDF와 첨부 파일 전체를 압축
            aside(*ngIf="attachmentPanelOpen && !showSyncConflictViewer()", class="absolute right-0 top-0 z-30 flex h-full w-[360px] max-w-[calc(100%-1rem)] flex-col border-l border-stone-200 bg-white shadow-xl dark:border-zinc-800 dark:bg-zinc-950")
                div(class="flex h-14 shrink-0 items-center justify-between border-b border-stone-200 px-4 dark:border-zinc-800")
                    div(class="min-w-0")
                        p(class="text-[14px] font-semibold text-stone-900 dark:text-zinc-100") 첨부 파일
                        p(class="text-[12px] text-stone-500 dark:text-zinc-400") {{attachmentCount()}}개
                    button(type="button", title="Close attachments", class="flex size-8 items-center justify-center rounded-md text-stone-500 transition hover:bg-stone-100 hover:text-stone-950 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-50", (click)="closeAttachmentPanel()")
                        svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M18 6 6 18")
                            path(d="m6 6 12 12")
                div(class="grid shrink-0 grid-cols-2 gap-2 border-b border-stone-200 p-3 dark:border-zinc-800")
                    button(type="button", class="h-9 rounded-md border border-stone-200 bg-white px-3 text-[12px] font-semibold text-stone-700 transition hover:bg-stone-50 disabled:cursor-not-allowed disabled:opacity-50 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800", (click)="triggerAttachmentUpload('file')", [disabled]="attachmentUploadBusy") 파일 첨부
                    button(type="button", class="h-9 rounded-md border border-stone-200 bg-white px-3 text-[12px] font-semibold text-stone-700 transition hover:bg-stone-50 disabled:cursor-not-allowed disabled:opacity-50 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800", (click)="triggerAttachmentUpload('image')", [disabled]="attachmentUploadBusy") 이미지 첨부
                    p(*ngIf="attachmentMessage", [class]="'col-span-2 ' + attachmentMessageClass()", aria-live="polite") {{attachmentMessage}}
                div(class="min-h-0 flex-1 overflow-y-auto p-2")
                    button(type="button", *ngFor="let attachment of visibleAttachments(); let i = index", class="flex w-full min-w-0 items-center gap-3 rounded-md px-2.5 py-2 text-left transition hover:bg-stone-100 dark:hover:bg-zinc-900", (click)="openAttachment(attachment, $event)")
                        span(class="flex size-9 shrink-0 items-center justify-center rounded-md bg-stone-100 text-stone-500 dark:bg-zinc-900 dark:text-zinc-400")
                            svg(*ngIf="!isImageAttachment(attachment)", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                                path(d="M14 2v6h6")
                            svg(*ngIf="isImageAttachment(attachment)", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                rect(x="3", y="3", width="18", height="18", rx="2")
                                circle(cx="9", cy="9", r="2")
                                path(d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21")
                        span(class="min-w-0 flex-1")
                            span(class="block truncate text-[13px] font-medium text-stone-800 dark:text-zinc-100", [title]="attachment.fileName") {{attachment.fileName}}
                            span(class="mt-0.5 block truncate text-[11px] text-stone-400 dark:text-zinc-500") {{attachmentKindLabel(attachment)}} {{attachmentSizeLabel(attachment.size)}}
                    div(*ngIf="visibleAttachments().length === 0", class="flex h-full min-h-[160px] items-center justify-center px-6 text-center text-[13px] text-stone-400 dark:text-zinc-500") 현재 노트에 첨부된 파일이 없습니다.
            div(*ngIf="attachmentPickerOpen && !showSyncConflictViewer()", data-attachment-picker="true", [ngStyle]="attachmentPickerStyle", class="absolute z-40 w-[380px] max-w-[calc(100%-2rem)] overflow-hidden rounded-md border border-stone-200 bg-white shadow-xl dark:border-zinc-800 dark:bg-zinc-950")
                div(class="border-b border-stone-200 px-3 py-2 dark:border-zinc-800")
                    p(class="text-[12px] font-semibold text-stone-900 dark:text-zinc-100") {{attachmentPickerMode === 'image' ? '이미지 삽입' : '파일 삽입'}}
                    p(class="text-[11px] text-stone-400 dark:text-zinc-500") Enter로 선택
                div(class="max-h-72 overflow-y-auto p-1.5")
                    button(type="button", *ngFor="let item of attachmentPickerItems; let i = index", [class]="attachmentPickerItemClass(i)", [attr.data-attachment-picker-index]="i", (mouseenter)="attachmentPickerIndex = i", (click)="chooseAttachmentPickerItem(item)")
                        span(class="flex size-8 shrink-0 items-center justify-center rounded-md bg-stone-100 text-stone-500 dark:bg-zinc-900 dark:text-zinc-400")
                            svg(*ngIf="item.type === 'upload'", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                path(d="M12 5v14")
                                path(d="M5 12h14")
                            svg(*ngIf="item.type === 'attachment' && !isImageAttachment(item.attachment)", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                                path(d="M14 2v6h6")
                            svg(*ngIf="item.type === 'attachment' && isImageAttachment(item.attachment)", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                rect(x="3", y="3", width="18", height="18", rx="2")
                                circle(cx="9", cy="9", r="2")
                                path(d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21")
                        span(class="min-w-0 flex-1")
                            span(class="block truncate text-[13px] font-semibold") {{item.label}}
                            span(class="mt-0.5 block truncate text-[11px] opacity-70") {{item.detail}}
            div(*ngIf="showSyncConflictViewer()", class="flex h-full min-h-0 flex-col gap-3 overflow-hidden p-4")
                nu-monaco-editor(class="pointer-events-none absolute h-px w-px opacity-0", [ngModel]="''", [options]="hiddenMonacoOptions", height="1px", (event)="onHiddenMonacoEvent($event)")
                div(class="flex shrink-0 flex-wrap items-center justify-between gap-3 border-b border-amber-200 pb-3 dark:border-amber-500/25")
                    div(class="min-w-0 flex-1")
                        p(class="text-[13px] font-semibold text-amber-900 dark:text-amber-100") 서버 버전과 로컬 버전 비교
                        p(class="mt-1 truncate font-mono text-[12px] text-stone-500 dark:text-zinc-400", [title]="syncConflictPathLabel()") {{syncConflictPathLabel()}}
                        p(*ngIf="syncConflictResolveMessage", [class]="syncConflictResolveMessageClass()", aria-live="polite") {{syncConflictResolveMessage}}
                    div(class="flex shrink-0 flex-wrap items-center gap-2")
                        div(class="flex rounded-lg border border-stone-200 bg-white p-1 shadow-sm dark:border-zinc-800 dark:bg-zinc-900")
                            button(type="button", [class]="syncConflictResolveChoiceButtonClass('server')", (click)="setSyncConflictResolveChoice('server')") 서버 버전 사용
                            button(type="button", [class]="syncConflictResolveChoiceButtonClass('local')", (click)="setSyncConflictResolveChoice('local')") 로컬 버전 사용
                        button(type="button", [class]="syncConflictApplyButtonClass()", (click)="resolveSelectedSyncConflict()", [disabled]="syncConflictResolveBusy || syncConflictBusy || !selectedSyncConflict()?.relativePath", [attr.aria-busy]="syncConflictResolveBusy") {{syncConflictResolveBusy ? '적용 중...' : '선택 버전 적용'}}
                div(class="grid min-h-0 flex-1 overflow-hidden gap-3 lg:grid-cols-[260px_minmax(0,1fr)]")
                    nav(class="h-full min-h-0 space-y-1 overflow-y-auto rounded-md border border-stone-200 bg-stone-50/80 p-1.5 dark:border-zinc-800 dark:bg-zinc-900/60")
                        button(type="button", *ngFor="let conflict of syncConflicts; let i = index", [class]="syncConflictButtonClass(i)", (click)="selectSyncConflict(i)")
                            span(class="min-w-0 truncate") {{syncConflictPathLabel(conflict)}}
                            span(class="shrink-0 text-[11px] tabular-nums") {{'#' + (i + 1)}}
                    div(class="flex min-h-0 min-w-0 flex-col overflow-hidden rounded-md border border-stone-200 bg-white dark:border-zinc-800 dark:bg-zinc-950")
                        div(class="grid shrink-0 border-b border-stone-200 text-[12px] font-semibold text-stone-600 dark:border-zinc-800 dark:text-zinc-300 lg:grid-cols-2")
                            div(class="border-b border-stone-200 px-3 py-2 dark:border-zinc-800 lg:border-b-0 lg:border-r") 서버 버전
                            div(class="px-3 py-2") 로컬 버전
                        div(class="relative min-h-0 flex-1 overflow-hidden")
                            div(id="notedown-sync-conflict-diff", class="absolute inset-0 h-full w-full overflow-hidden")
                            div(*ngIf="!syncConflictDiffReady", class="absolute inset-0 flex items-center justify-center bg-white/95 p-4 dark:bg-zinc-950/95")
                                div(class="flex flex-col items-center gap-3 text-center")
                                    span(class="size-8 rounded-full border-2 border-stone-200 border-t-amber-500 animate-spin dark:border-zinc-800 dark:border-t-amber-300")
                                    p(class="text-[13px] font-semibold text-stone-700 dark:text-zinc-200") {{syncConflictBusy ? '충돌 파일을 불러오는 중입니다...' : 'Monaco diff editor를 불러오는 중입니다...'}}
            div(*ngIf="!showSyncConflictViewer()", class="grid h-full min-h-0", [ngClass]="editorGridClass()")
                div(class="flex min-h-0 flex-col", *ngIf="viewMode !== 'preview'")
                    div(*ngIf="showMarkdownToolbar()", data-markdown-toolbar="true", class="flex h-11 shrink-0 items-center gap-1 overflow-x-auto border-b border-stone-200 bg-stone-50/90 px-2 dark:border-zinc-800 dark:bg-zinc-900/70")
                        div(class="shrink-0")
                            button(type="button", title="제목", aria-label="제목", [class]="headingToolbarButtonClass()", (click)="toggleHeadingMenu()") H1
                        button(type="button", *ngFor="let action of markdownToolbarActions", [title]="action.title", [attr.aria-label]="action.title", [class]="markdownToolbarButtonClass(action.id)", (click)="applyMarkdownToolbarAction(action.id)")
                            svg(*ngIf="action.id === 'task'", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                rect(x="4", y="4", width="16", height="16", rx="3")
                                path(d="m8 12 2.5 2.5L16 9")
                            svg(*ngIf="action.id === 'bullet'", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                path(d="M9 6h11")
                                path(d="M9 12h11")
                                path(d="M9 18h11")
                                path(d="M4 6h.01")
                                path(d="M4 12h.01")
                                path(d="M4 18h.01")
                            svg(*ngIf="action.id === 'quote'", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                path(d="M8 10h5")
                                path(d="M8 14h8")
                                path(d="M5 19V5")
                            svg(*ngIf="action.id === 'code'", xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                                path(d="m8 9-3 3 3 3")
                                path(d="m16 9 3 3-3 3")
                                path(d="m14 5-4 14")
