section(class="flex h-full min-h-0 flex-col bg-white text-stone-950 dark:bg-zinc-950 dark:text-zinc-50")
    ng-container(*ngIf="hasSelectedNote")
        header(class="app-drag flex h-14 shrink-0 items-center justify-between border-b border-stone-200 bg-white px-5 dark:border-zinc-800 dark:bg-zinc-950")
            div(class="min-w-0 flex flex-1 items-center")
                div(*ngIf="!editingTitle", class="min-w-0 flex max-w-full items-center gap-1.5")
                    span(class="min-w-0 truncate text-[16px] font-semibold text-stone-900 dark:text-zinc-100", [title]="noteTitleLabel()") {{noteTitleLabel()}}
                    button(type="button", title="Edit title", aria-label="Edit title", class="flex size-8 shrink-0 items-center justify-center rounded-md text-stone-400 transition hover:bg-stone-100 hover:text-stone-950 dark:text-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-50", (click)="startTitleEdit()")
                        svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M12 20h9")
                            path(d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z")
                input(*ngIf="editingTitle", type="text", [(ngModel)]="titleDraft", (keydown.enter)="commitTitleEdit()", (keydown.escape)="cancelTitleEdit()", (blur)="commitTitleEdit()", data-note-title-input="true", class="app-no-drag min-w-0 w-full border-0 bg-transparent p-0 text-[16px] font-semibold text-stone-900 outline-none placeholder:text-stone-300 focus:ring-0 dark:text-zinc-100 dark:placeholder:text-zinc-700", placeholder="제목 없음")
            div(class="flex shrink-0 items-center gap-2 pl-4")
                span(class="hidden whitespace-nowrap text-[12px] text-stone-400 sm:inline dark:text-zinc-500") 생성: {{createdAtLabel()}} · 저장: {{lastSavedLabel()}}
                div(class="flex rounded-lg border border-stone-200 bg-white/95 p-1 shadow-sm backdrop-blur dark:border-zinc-800 dark:bg-zinc-900/95")
                    button(type="button", title="Write", [class]="modeButtonClass('write')", (click)="setMode('write')")
                        svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M12 20h9")
                            path(d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z")
                    button(type="button", title="Split", [class]="modeButtonClass('split')", (click)="setMode('split')")
                        svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            rect(x="3", y="4", width="18", height="16", rx="2")
                            path(d="M12 4v16")
                    button(type="button", title="Preview", [class]="modeButtonClass('preview')", (click)="setMode('preview')")
                        svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                            path(d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z")
                            circle(cx="12", cy="12", r="3")
                button(type="button", title="Toggle line numbers", [class]="lineNumberButtonClass()", (click)="toggleLineNumbers()")
                    svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                        path(d="M8 6h12")
                        path(d="M8 12h12")
                        path(d="M8 18h12")
                        path(d="M3 6h.01")
                        path(d="M3 12h.01")
                        path(d="M3 18h.01")
                button(type="button", title="Save PDF", class="ml-2 flex size-9 items-center justify-center rounded-md text-stone-500 transition hover:bg-stone-100 hover:text-stone-950 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-50", (click)="exportNotePdf()")
                    svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                        path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                        path(d="M14 2v6h6")
                        path(d="M12 12v6")
                        path(d="m9 15 3 3 3-3")

        div(class="relative min-h-0 flex-1 bg-white dark:bg-zinc-950")
            div(class="grid h-full min-h-0", [ngClass]="viewMode === 'split' ? 'lg:grid-cols-2' : 'grid-cols-1'")
                div(class="min-h-0", *ngIf="viewMode !== 'preview'")
                    nu-monaco-editor(class="block h-full min-h-0", [ngModel]="activeNote.body", (ngModelChange)="handleBodyChange($event)", [options]="editorOptions", height="100%", placeholder="Markdown", (event)="onEditorEvent($event)")
                div(class="min-h-0 overflow-auto border-stone-200 p-2 dark:border-zinc-800", *ngIf="viewMode !== 'write'", [ngClass]="viewMode === 'split' ? 'border-t lg:border-l lg:border-t-0' : ''")
                    style(*ngIf="documentStyleCss", type="text/css", [textContent]="documentStyleCss")
                    div(class="notedown-preview-flow notedown-preview-document w-full max-w-none", [attr.style]="documentGlobalStyle || null", [class.has-line-numbers]="showLineNumbers", [class.has-text-style]="documentGlobalHasTextStyle", (click)="handlePreviewClick($event)", (mouseover)="handlePreviewMouseOver($event)", (mouseleave)="clearSyncedLineHover()")
                        ng-container(*ngFor="let block of previewBlocks")
                            div(*ngIf="block.type === 'blank'", [class]="previewBlockClass(block)", [attr.style]="block.sectionStyle || null", [attr.data-preview-line]="block.lineIndex")
                                span(*ngIf="showLineNumbers", [class]="previewLineNumberClass(block)")
                                    span(*ngFor="let lineNumber of previewLineNumbers(block)") {{lineNumber + 1}}
                                div(class="notedown-preview-content")
                            div(*ngIf="block.type === 'markdown'", [class]="previewBlockClass(block)", [attr.style]="block.sectionStyle || null", [attr.data-preview-line]="block.lineIndex")
                                span(*ngIf="showLineNumbers", [class]="previewLineNumberClass(block)")
                                    span(*ngFor="let lineNumber of previewLineNumbers(block)") {{lineNumber + 1}}
                                div(class="notedown-preview-content")
                                    div(class="notedown-preview-markdown prose prose-stone max-w-none prose-headings:font-semibold prose-a:text-blue-600 dark:prose-invert dark:prose-a:text-blue-300", [innerHTML]="block.html")
                            div(*ngIf="block.type === 'code'", [class]="previewBlockClass(block)", [attr.style]="block.sectionStyle || null", [attr.data-preview-line]="block.lineIndex")
                                span(*ngIf="showLineNumbers", [class]="previewLineNumberClass(block)")
                                    span(*ngFor="let lineNumber of previewLineNumbers(block)") {{lineNumber + 1}}
                                div(class="notedown-preview-content")
                                    nu-monaco-editor(class="block", [ngModel]="block.code", [options]="codePreviewOptions(block)", [height]="codePreviewHeight(block.code)")

    ng-container(*ngIf="!hasSelectedNote")
        header(class="app-drag flex h-14 shrink-0 items-center justify-between border-b border-stone-200 bg-white px-5 dark:border-zinc-800 dark:bg-zinc-950")
            div(class="min-w-0 flex flex-1 items-center")
                span(class="truncate text-[16px] font-semibold text-stone-500 dark:text-zinc-400") 노트가 선택되지 않았습니다
            button(type="button", title="New note", class="flex size-9 items-center justify-center rounded-md text-stone-500 transition hover:bg-stone-100 hover:text-stone-950 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-50", (click)="createNote()")
                svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.8", stroke-linecap="round", stroke-linejoin="round", class="size-4")
                    path(d="M12 5v14")
                    path(d="M5 12h14")
        div(class="flex min-h-0 flex-1 items-center justify-center bg-white px-6 dark:bg-zinc-950")
            div(class="flex max-w-sm flex-col items-center gap-4 text-center")
                svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="1.6", stroke-linecap="round", stroke-linejoin="round", class="size-10 text-stone-300 dark:text-zinc-700")
                    path(d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z")
                    path(d="M14 2v4a2 2 0 0 0 2 2h4")
                    path(d="M10 12h4")
                    path(d="M10 16h4")
                h2(class="text-[18px] font-semibold text-stone-700 dark:text-zinc-200") 노트가 선택되지 않았습니다
                button(type="button", class="h-9 rounded-md bg-stone-900 px-4 text-[13px] font-semibold text-white transition hover:bg-stone-700 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200", (click)="createNote()") 새 노트
